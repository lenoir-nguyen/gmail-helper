# ─────────────────────────────────────────────
#  BACKEND  (copy to backend/.env)
# ─────────────────────────────────────────────

# OpenAI
OPENAI_API_KEY=sk-...

# Google OAuth — from Google Cloud Console
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# OAuth redirect URI — must match Google Cloud Console exactly
# Local dev:  http://localhost:8000/auth/google/callback
# Production: https://your-backend.railway.app/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Frontend URL — used to redirect after OAuth
# Local dev:  http://localhost:3000
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────
#  FRONTEND  (copy to frontend/.env.local)
# ─────────────────────────────────────────────

# Backend URL
# Local dev:  http://localhost:8000
# Production: https://your-backend.railway.app
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
